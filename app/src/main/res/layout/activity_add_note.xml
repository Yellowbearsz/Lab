<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_class_header"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_name"
            android:importantForAutofill="no"
            android:inputType="textPersonName"/>

        <EditText
            android:id="@+id/etUserId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_id"
            android:inputType="number"
            android:importantForAutofill="no"/>

        <RadioGroup
            android:id="@+id/rgUserType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="8dp">
            <RadioButton
                android:id="@+id/rbGeneralPublic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_general_public"
                android:checked="true"
                android:buttonTint="#6200EE"/>
            <RadioButton
                android:id="@+id/rbSubscription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_subscription"
                android:layout_marginStart="16dp"
                android:buttonTint="#6200EE"/>
        </RadioGroup>

        <EditText
            android:id="@+id/etMemberExpired"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_member_expired"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            android:importantForAutofill="no"
            android:inputType="date"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/note_class_header"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_title"
            android:importantForAutofill="no"
            android:inputType="text"/>

        <RadioGroup
            android:id="@+id/rgNoteType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="8dp">
            <RadioButton
                android:id="@+id/rbTextNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_text_note"
                android:checked="true"
                android:buttonTint="#6200EE"/>
            <RadioButton
                android:id="@+id/rbChecklistNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_checklist_note"
                android:layout_marginStart="16dp"
                android:buttonTint="#6200EE"/>
        </RadioGroup>

        <EditText
            android:id="@+id/etNoteContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_note_content"
            android:lines="3"
            android:gravity="top"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_note"
            android:background="#6200EE"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="24dp"/>
    </LinearLayout>
</ScrollView>